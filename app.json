{
  "expo": {
    "name": "MeterBuddy",
    "slug": "MeterBuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-cube.png",
    "scheme": "meterbuddy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-icon-cube.png",
      "bundleIdentifier": "com.meterbuddy.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.meterbuddy.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app-icon-cube.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow MeterBuddy to use your camera to scan utility meters."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "99480d48-381c-47ee-b624-37960ff9d3e7"
      }
    }
  }
}
